Package: rayvertex
Type: Package
Title: 3D Software Rasterizer
Version: 0.15.0
Date: 2026-05-25
Authors@R: c(person("Tyler", "Morgan-Wall", email = "tylermw@gmail.com", 
    role = c("aut", "cph", "cre"), comment = c(ORCID = "0000-0002-3131-3814")),
    person("Syoyo", "Fujita", role=c("ctb", "cph")),
